{
  "name": "apple-swift-format",
  "description": "Automatic Swift formatting and linting using apple/swift-format",
  "version": "1.1.0",
  "author": {
    "name": "giginet"
  },
  "homepage": "https://github.com/giginet/claude-code-plugins/tree/main/plugins/apple-swift-format",
  "repository": "https://github.com/giginet/claude-code-plugins",
  "license": "MIT",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.swift)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/swift-format-format.sh"
          },
          {
            "type": "command",
            "if": "Write(*.swift)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/swift-format-format.sh"
          },
          {
            "type": "command",
            "if": "MultiEdit(*.swift)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/swift-format-format.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.swift)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/swift-format-lint.sh"
          },
          {
            "type": "command",
            "if": "Write(*.swift)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/swift-format-lint.sh"
          },
          {
            "type": "command",
            "if": "MultiEdit(*.swift)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/swift-format-lint.sh"
          }
        ]
      }
    ]
  }
}
